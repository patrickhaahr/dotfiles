{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "theme": "system",
  "instructions": ["AGENTS*.md"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn@latest","mcp"],
      "enabled": false
    },
  },
}
